{
    "require-dev": {
        "kahlan/kahlan": "^6.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src"
        }
    },
    "scripts": {
        "test": "vendor/bin/kahlan",
        "lint": "vendor/bin/php-cs-fixer fix --diff",
        "lint-ci": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "phpstan": "vendor/bin/phpstan analyse"
    }
}
